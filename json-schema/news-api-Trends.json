{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trends",
  "properties": {
    "field": {
      "description": "The field of trends",
      "type": "string"
    },
    "trends": {
      "description": "An array of trends",
      "items": {
        "$ref": "#/components/schemas/Trend"
      },
